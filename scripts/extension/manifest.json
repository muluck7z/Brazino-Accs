{
  "manifest_version": 3,
  "name": "Brazino Accs",
  "version": "1.0.0",
  "description": "Salva credenciais de contas Roblox no seu vault pessoal.",
  "permissions": ["storage", "activeTab", "scripting"],
  "host_permissions": ["https://www.roblox.com/*", "https://roblox.com/*"],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Brazino Accs"
  },
  "options_page": "options.html",
  "content_scripts": [
    {
      "matches": ["https://www.roblox.com/*", "https://roblox.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
